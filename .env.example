# =============================================================================
# META / WHATSAPP BUSINESS API
# =============================================================================
# Token de acesso permanente gerado no Meta for Developers
META_ACCESS_TOKEN=your_meta_permanent_access_token_here

# ID do numero de telefone registrado no WhatsApp Business
META_PHONE_NUMBER_ID=115216611574100

# Token de verificacao do webhook (deve coincidir com o configurado no painel Meta)
META_VERIFY_TOKEN=drTrafegoWA_2025Xk9P

# App Secret do Meta App (usado para validar assinatura do webhook)
META_APP_SECRET=your_meta_app_secret_here

# =============================================================================
# SUPABASE
# =============================================================================
# URL do projeto Supabase
SUPABASE_URL=https://your-project-id.supabase.co

# Chave de servico (service role) com acesso total — nao expor no frontend
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Connection string PostgreSQL (pooler ou direct)
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# =============================================================================
# REDIS (Upstash para Vercel — https://upstash.com)
# =============================================================================
# URL do Upstash Redis (formato: rediss://default:TOKEN@endpoint:6380)
# Para dev local use: redis://redis:6379
REDIS_URL=rediss://default:your_upstash_token@your-endpoint.upstash.io:6380

# TTL do lock de sessao em segundos (evita processar msgs duplicadas)
REDIS_LOCK_TTL=90

# =============================================================================
# LLM (MODELOS DE LINGUAGEM)
# =============================================================================
# Provider ativo: gemini | anthropic | openai
LLM_PROVIDER=gemini

# API Keys — preencha apenas o provider ativo
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Modelo especifico a usar. Se vazio, usa o default do provider:
#   gemini    -> gemini-2.0-flash
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4o-mini
LLM_MODEL=

# =============================================================================
# GOOGLE CALENDAR
# =============================================================================
# ID do calendario (use "primary" para o calendario principal)
GOOGLE_CALENDAR_ID=primary

# Credenciais da Service Account em formato JSON inline (string em uma linha)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# =============================================================================
# OUTPUT / BOT SEND
# =============================================================================
# URL do endpoint que envia mensagens WhatsApp
BOT_SEND_URL=https://agente.casaldotrafego.com/api/whatsapp/bot-send

# Token de autenticacao para o endpoint bot-send
BOT_SEND_TOKEN=your_bot_send_token_here

# =============================================================================
# NOTIFICACOES INTERNAS
# =============================================================================
# Numero de telefone para notificacoes internas (sem + e sem espacos)
NOTIFY_PHONE=5491151133210

# =============================================================================
# FOLLOW-UP
# =============================================================================
# Intervalo em minutos entre checagens do scheduler de follow-up
FOLLOWUP_INTERVAL_MINUTES=30

# Horas de espera antes de disparar o primeiro follow-up (FU0)
FOLLOWUP_FU0_DELAY_HOURS=2

# =============================================================================
# APLICACAO
# =============================================================================
# Ambiente: development | staging | production
APP_ENV=development

# Nivel de log: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Porta HTTP do servidor FastAPI
PORT=8000
